# Variables optionnelles pour l'alpha publique (frontend)
# Copier en frontend/.env.local et adapter avant build Netlify

# URL de déploiement (affichée dans le README / docs)
VITE_NETLIFY_URL=https://votre-site.netlify.app

# Feedback joueurs
VITE_FEEDBACK_EMAIL=
VITE_FEEDBACK_DISCORD=
VITE_FEEDBACK_TWITTER=

# Forcer le mode démo (dev)
# VITE_NETLIFY=true

# Backend local (dev avec serveur Python)
# VITE_API_BASE=http://127.0.0.1:8000/api
